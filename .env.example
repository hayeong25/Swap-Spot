# 한국수출입은행 API 키 (https://www.koreaexim.go.kr 에서 발급)
KOREAEXIM_API_KEY=your_api_key_here

# 한국은행 ECOS API 키 (https://ecos.bok.or.kr/api/ 에서 발급)
ECOS_API_KEY=your_api_key_here

# 텔레그램 봇 알림 (선택사항)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 데이터베이스 (기본: SQLite, PostgreSQL도 지원)
# DATABASE_URL=postgresql://user:password@host:5432/swap_spot

# 서버 설정
HOST=0.0.0.0
PORT=8000
# ENV=production  # production 설정 시 로그 레벨 WARNING, SSL 검증 활성화
